<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Lista de Tarefas</title>
  <link rel="icon" href="/favicon.png">
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <main class="container">
    <section class="card">

      <header class="topo">
        <div style="display:flex; justify-content:space-between; align-items:center; gap:12px; flex-wrap:wrap;">
          <div>
            <h1>Lista de Tarefas</h1>
            <p>Organize o dia por categorias, prioridades e pendências.</p>
          </div>

          <div style="display:flex; align-items:center; gap:10px;">
            <span>Olá, <strong><%= @usuario_atual['nome'] %></strong></span>

            <form action="/logout" method="post" style="margin:0;">
              <button type="submit" class="btn excluir">Sair</button>
            </form>
          </div>
        </div>
      </header>

      <% unless @mensagem.to_s.empty? %>
        <div class="mensagem">
          <%= @mensagem %>
        </div>
      <% end %>

      <form action="/tarefas" method="post" class="nova-tarefa-form">
        <input
          type="text"
          name="texto"
          placeholder="Digite uma nova tarefa..."
          maxlength="120"
          required
        >

        <input
          type="text"
          name="categoria"
          placeholder="Categoria ou pendência (ex: Fortes)"
          maxlength="60"
          required
        >

        <select name="prioridade">
          <option value="alta">Alta</option>
          <option value="media" selected>Média</option>
          <option value="baixa">Baixa</option>
        </select>

        <button type="submit">Adicionar</button>
      </form>

      <div class="resumo">
        <span>Todas: <strong><%= @total_tarefas %></strong></span>
        <span>Pendentes: <strong><%= @total_pendentes %></strong></span>
        <span>Concluídas: <strong><%= @total_concluidas %></strong></span>
      </div>

      <div class="filtros">
        <a href="/?filtro=todas" class="filtro-btn <%= 'ativo' if @filtro == 'todas' %>">
          Todas
          <span class="contador"><%= @total_tarefas %></span>
        </a>

        <a href="/?filtro=pendentes" class="filtro-btn <%= 'ativo' if @filtro == 'pendentes' %>">
          Pendentes
          <span class="contador"><%= @total_pendentes %></span>
        </a>

        <a href="/?filtro=concluidas" class="filtro-btn <%= 'ativo' if @filtro == 'concluidas' %>">
          Concluídas
          <span class="contador"><%= @total_concluidas %></span>
        </a>
      </div>

      <% if @tarefas_por_categoria.empty? %>
        <div class="vazio">
          Nenhuma tarefa encontrada neste filtro.
        </div>
      <% else %>
        <% @tarefas_por_categoria.each_with_index do |(categoria, tarefas), index| %>
          <section class="bloco-categoria">
            <button
              type="button"
              class="cabecalho-categoria botao-categoria"
              onclick="alternarCategoria('categoria-<%= index %>')"
            >
              <div class="titulo-categoria">
                <span class="seta">▸</span>
                <h2><%= categoria %></h2>
              </div>

              <span class="badge-categoria"><%= tarefas.count %> tarefa(s)</span>
            </button>

            <div id="categoria-<%= index %>" class="conteudo-categoria escondido">
              <div class="lista">
                <% tarefas.each do |tarefa| %>
                  <div class="item <%= 'concluida' if tarefa[:concluida] %> prioridade-<%= tarefa[:prioridade] %>">

                    <div class="conteudo-tarefa">
                      <div class="texto">
                        <%= tarefa[:texto] %>
                      </div>

                      <div class="meta">
                        Prioridade:
                        <span class="tag-prioridade <%= tarefa[:prioridade] %>">
                          <%= tarefa[:prioridade].capitalize %>
                        </span>
                      </div>

                      <div class="observacoes-modulo">
                        <button
                          type="button"
                          class="btn-observacoes-toggle"
                          onclick="alternarObservacoes('obs-<%= tarefa[:id] %>', this)"
                        >
                          <span>Observações</span>
                          <span class="observacoes-badge" id="badge-observacoes-<%= tarefa[:id] %>"><%= tarefa[:observacoes].length %></span>
                        </button>

                        <div id="obs-<%= tarefa[:id] %>" class="observacoes-painel escondido">
                          <div class="observacoes-topo">
                            <h3>Observações da tarefa</h3>

                            <button
                              type="button"
                              class="btn-nova-observacao"
                              onclick="alternarFormularioObservacao('form-obs-<%= tarefa[:id] %>')"
                            >
                              Nova observação
                            </button>
                          </div>

                          <div
                            class="lista-observacoes <%= 'escondido' if tarefa[:observacoes].empty? %>"
                            id="lista-observacoes-<%= tarefa[:id] %>"
                          >
                            <% tarefa[:observacoes].each do |observacao| %>
                              <div class="observacao-item" id="observacao-<%= observacao[:id] %>">
                                <div class="observacao-texto">
                                  <%= observacao[:texto] %>
                                </div>

                                <button
                                  type="button"
                                  class="btn-excluir-observacao"
                                  onclick="excluirObservacao(<%= observacao[:id] %>, <%= tarefa[:id] %>)"
                                >
                                  Excluir
                                </button>
                              </div>
                            <% end %>
                          </div>

                          <div
                            class="sem-observacoes <%= 'escondido' unless tarefa[:observacoes].empty? %>"
                            id="sem-observacoes-<%= tarefa[:id] %>"
                          >
                            Nenhuma observação adicionada.
                          </div>

                          <form
                            id="form-obs-<%= tarefa[:id] %>"
                            action="/tarefas/<%= tarefa[:id] %>/observacoes"
                            method="post"
                            class="form-observacao escondido"
                            data-tarefa-id="<%= tarefa[:id] %>"
                          >
                            <textarea
                              name="observacao"
                              rows="4"
                              placeholder="Digite uma observação para esta tarefa..."
                              required
                            ></textarea>

                            <div class="acoes-observacao">
                              <button type="submit" class="btn btn-observacao">
                                Salvar observação
                              </button>
                            </div>
                          </form>
                        </div>
                      </div>
                    </div>

                    <div class="acoes">
                      <form action="/tarefas/<%= tarefa[:id] %>/concluir" method="post">
                        <button type="submit" class="btn concluir">
                          <%= tarefa[:concluida] ? 'Desmarcar' : 'Concluir' %>
                        </button>
                      </form>

                      <form action="/tarefas/<%= tarefa[:id] %>/excluir" method="post" onsubmit="return confirm('Excluir esta tarefa?')">
                        <button type="submit" class="btn excluir">
                          Excluir
                        </button>
                      </form>
                    </div>

                  </div>
                <% end %>
              </div>
            </div>
          </section>
        <% end %>
      <% end %>

      <% if @total_concluidas > 0 %>
        <form action="/limpar_concluidas" method="post" class="rodape-acoes" onsubmit="return confirm('Remover todas as tarefas concluídas?')">
          <button type="submit" class="btn limpar">
            Limpar concluídas
          </button>
        </form>
      <% end %>

    </section>
  </main>

  <script>
    function alternarCategoria(id) {
      const conteudo = document.getElementById(id)
      const botao = conteudo.previousElementSibling
      const seta = botao.querySelector('.seta')

      conteudo.classList.toggle('escondido')
      botao.classList.toggle('aberta')

      if (conteudo.classList.contains('escondido')) {
        seta.textContent = '▸'
      } else {
        seta.textContent = '▾'
      }
    }

    function alternarObservacoes(id, botao) {
      const painel = document.getElementById(id)
      painel.classList.toggle('escondido')
      botao.classList.toggle('ativo')
    }

    function alternarFormularioObservacao(id) {
      const formulario = document.getElementById(id)
      formulario.classList.toggle('escondido')
    }

    function escapeHtml(texto) {
      const div = document.createElement('div')
      div.textContent = texto
      return div.innerHTML
    }

    function criarHtmlObservacao(observacao, tarefaId) {
      return `
        <div class="observacao-item" id="observacao-${observacao.id}">
          <div class="observacao-texto">
            ${escapeHtml(observacao.texto)}
          </div>

          <button
            type="button"
            class="btn-excluir-observacao"
            onclick="excluirObservacao(${observacao.id}, ${tarefaId})"
          >
            Excluir
          </button>
        </div>
      `
    }

    function mostrarMensagem(texto, tipo = 'sucesso') {
      let mensagem = document.querySelector('.mensagem')

      if (!mensagem) {
        mensagem = document.createElement('div')
        mensagem.className = 'mensagem'
        const topo = document.querySelector('.topo')
        topo.insertAdjacentElement('afterend', mensagem)
      }

      mensagem.textContent = texto
      mensagem.dataset.tipo = tipo

      clearTimeout(mensagem._timer)

      mensagem._timer = setTimeout(() => {
        mensagem.textContent = ''
      }, 3000)
    }

    function atualizarBadgeObservacoes(tarefaId, quantidade) {
      const badge = document.getElementById(`badge-observacoes-${tarefaId}`)
      if (badge) {
        badge.textContent = quantidade
      }
    }

    async function excluirObservacao(observacaoId, tarefaId) {
      const confirmou = confirm('Excluir esta observação?')
      if (!confirmou) return

      const item = document.getElementById(`observacao-${observacaoId}`)
      const lista = document.getElementById(`lista-observacoes-${tarefaId}`)
      const vazio = document.getElementById(`sem-observacoes-${tarefaId}`)

      try {
        const resposta = await fetch(`/observacoes/${observacaoId}/excluir`, {
          method: 'POST',
          headers: {
            'Accept': 'application/json'
          }
        })

        const dados = await resposta.json()

        if (!resposta.ok || !dados.sucesso) {
          mostrarMensagem(dados.mensagem || 'Erro ao excluir observação', 'erro')
          return
        }

        if (item) {
          item.remove()
        }

        const quantidadeRestante = lista ? lista.querySelectorAll('.observacao-item').length : 0
        atualizarBadgeObservacoes(tarefaId, quantidadeRestante)

        if (quantidadeRestante === 0) {
          lista.classList.add('escondido')
          vazio.classList.remove('escondido')
        }

        mostrarMensagem(dados.mensagem || 'Observação excluída com sucesso')
      } catch (erro) {
        mostrarMensagem('Erro de conexão ao excluir observação', 'erro')
      }
    }

    document.querySelectorAll('.form-observacao').forEach((formulario) => {
      formulario.addEventListener('submit', async (event) => {
        event.preventDefault()

        const tarefaId = formulario.dataset.tarefaId
        const textarea = formulario.querySelector('textarea')
        const botao = formulario.querySelector('button[type="submit"]')
        const lista = document.getElementById(`lista-observacoes-${tarefaId}`)
        const vazio = document.getElementById(`sem-observacoes-${tarefaId}`)
        const painel = document.getElementById(`obs-${tarefaId}`)

        const texto = textarea.value.trim()

        if (!texto) {
          mostrarMensagem('Digite uma observação válida', 'erro')
          return
        }

        botao.disabled = true
        botao.textContent = 'Salvando...'

        try {
          const resposta = await fetch(formulario.action, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/x-www-form-urlencoded',
              'Accept': 'application/json'
            },
            body: new URLSearchParams({
              observacao: texto
            })
          })

          const dados = await resposta.json()

          if (!resposta.ok || !dados.sucesso) {
            mostrarMensagem(dados.mensagem || 'Erro ao salvar observação', 'erro')
            return
          }

          lista.insertAdjacentHTML('beforeend', criarHtmlObservacao(dados.observacao, tarefaId))
          lista.classList.remove('escondido')
          vazio.classList.add('escondido')

          const quantidadeAtual = lista.querySelectorAll('.observacao-item').length
          atualizarBadgeObservacoes(tarefaId, quantidadeAtual)

          textarea.value = ''
          formulario.classList.add('escondido')

          if (painel.classList.contains('escondido')) {
            painel.classList.remove('escondido')
          }

          mostrarMensagem(dados.mensagem || 'Observação adicionada com sucesso')
        } catch (erro) {
          mostrarMensagem('Erro de conexão ao salvar observação', 'erro')
        } finally {
          botao.disabled = false
          botao.textContent = 'Salvar observação'
        }
      })
    })
  </script>
</body>
</html>