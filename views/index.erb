<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Lista de Tarefas</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <main class="container">
    <section class="card">
      <header class="topo">
        <h1>Lista de Tarefas</h1>
        <p>Organize o dia de forma simples.</p>
      </header>

      <form action="/tarefas" method="post" class="nova-tarefa-form">
        <input
          type="text"
          name="texto"
          placeholder="Digite uma nova tarefa..."
          maxlength="120"
          required
        >

        <select name="prioridade" required>
          <option value="alta">Alta</option>
          <option value="media" selected>Média</option>
          <option value="baixa">Baixa</option>
        </select>

        <button type="submit">Adicionar</button>
      </form>

      <div class="resumo">
        <span>Pendentes: <strong><%= @total_pendentes %></strong></span>
        <span>Concluídas: <strong><%= @total_concluidas %></strong></span>
      </div>

      <div class="filtros">
  <a href="/?filtro=todas"
     class="filtro-btn <%= 'ativo' if @filtro == 'todas' %>">
     Todas
  </a>

  <a href="/?filtro=pendentes"
     class="filtro-btn <%= 'ativo' if @filtro == 'pendentes' %>">
     Pendentes
  </a>

  <a href="/?filtro=concluidas"
     class="filtro-btn <%= 'ativo' if @filtro == 'concluidas' %>">
     Concluídas
  </a>
</div>

      <div class="lista">
        <% if @tarefas.empty? %>
          <div class="vazio">
            Nenhuma tarefa encontrada neste filtro.
          </div>
        <% else %>
          <% @tarefas.each do |tarefa| %>
            <div class="item <%= 'concluida' if tarefa[:concluida] %> prioridade-<%= tarefa[:prioridade] || 'media' %>">
              <div class="conteudo-tarefa">
                <div class="texto">
                  <%= tarefa[:texto] %>
                </div>

                <div class="meta">
                  Prioridade:
                  <span class="tag-prioridade <%= tarefa[:prioridade] || 'media' %>">
                    <%= (tarefa[:prioridade] || 'media').capitalize %>
                  </span>
                </div>
              </div>

              <div class="acoes">
                <form action="/tarefas/<%= tarefa[:id] %>/concluir" method="post">
                  <button type="submit" class="btn concluir">
                    <%= tarefa[:concluida] ? 'Desmarcar' : 'Concluir' %>
                  </button>
                </form>

                <form action="/tarefas/<%= tarefa[:id] %>/excluir" method="post" onsubmit="return confirm('Excluir esta tarefa?')">
                  <button type="submit" class="btn excluir">Excluir</button>
                </form>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>

      <% if @total_concluidas > 0 %>
        <form action="/limpar_concluidas" method="post" class="rodape-acoes" onsubmit="return confirm('Remover todas as tarefas concluídas?')">
          <button type="submit" class="btn limpar">Limpar concluídas</button>
        </form>
      <% end %>
    </section>
  </main>
</body>
</html>